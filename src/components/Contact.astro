---
import es from '../i18n/es.json';
import en from '../i18n/en.json';
---

<section id="contacto">
  <div id="contact">
    <div class="container">
      <div class="contact-inner">
        <!-- Encabezado -->
        <div class="contact-header fade-in">
          <h2 class="section-title lang-es">{es.contact.title}</h2>
          <h2 class="section-title lang-en">{en.contact.title}</h2>
          <p class="section-subtitle lang-es">{es.contact.subtitle}</p>
          <p class="section-subtitle lang-en">{en.contact.subtitle}</p>
        </div>

        <div class="contact-columns">
          <!-- Formulario -->
          <div class="contact-form-wrapper fade-in fade-in-delay-1">
            <!--
              Formulario con mailto: como fallback simple sin backend.
              Para activar envío real, reemplaza action con un endpoint Formspree:
              action="https://formspree.io/f/TU_FORM_ID" method="POST"
            -->
            <form
              class="contact-form"
              action="mailto:juancarlosvallejo3@gmail.com"
              method="GET"
              enctype="text/plain"
              id="contact-form"
            >
              <div class="form-row">
                <div class="form-group">
                  <label for="name-es" class="lang-es">{es.contact.form.name}</label>
                  <label for="name-en" class="lang-en">{en.contact.form.name}</label>
                  <input
                    type="text"
                    id="name-es"
                    name="name"
                    required
                    autocomplete="name"
                    class="lang-es"
                    placeholder="Juan García"
                  />
                  <input
                    type="text"
                    id="name-en"
                    name="name"
                    required
                    autocomplete="name"
                    class="lang-en"
                    placeholder="John Smith"
                  />
                </div>

                <div class="form-group">
                  <label for="company-es" class="lang-es">{es.contact.form.company}</label>
                  <label for="company-en" class="lang-en">{en.contact.form.company}</label>
                  <input
                    type="text"
                    id="company-es"
                    name="company"
                    autocomplete="organization"
                    class="lang-es"
                    placeholder="Talleres Metalwork S.L."
                  />
                  <input
                    type="text"
                    id="company-en"
                    name="company"
                    autocomplete="organization"
                    class="lang-en"
                    placeholder="Metalwork Industries Ltd."
                  />
                </div>
              </div>

              <div class="form-group">
                <label for="email" class="lang-es">{es.contact.form.email}</label>
                <label for="email-en" class="lang-en">{en.contact.form.email}</label>
                <input
                  type="email"
                  id="email"
                  name="email"
                  required
                  autocomplete="email"
                  placeholder="tu@empresa.com"
                />
              </div>

              <div class="form-group">
                <label for="message-es" class="lang-es">{es.contact.form.message}</label>
                <label for="message-en" class="lang-en">{en.contact.form.message}</label>
                <textarea
                  id="message-es"
                  name="message"
                  required
                  rows="5"
                  class="lang-es"
                  placeholder={es.contact.form.messagePlaceholder}
                ></textarea>
                <textarea
                  id="message-en"
                  name="message"
                  required
                  rows="5"
                  class="lang-en"
                  placeholder={en.contact.form.messagePlaceholder}
                ></textarea>
              </div>

              <button type="submit" class="btn btn-primary btn-lg submit-btn">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <line x1="22" y1="2" x2="11" y2="13"/>
                  <polygon points="22 2 15 22 11 13 2 9 22 2"/>
                </svg>
                <span class="lang-es">{es.contact.form.submit}</span>
                <span class="lang-en">{en.contact.form.submit}</span>
              </button>
            </form>
          </div>

          <!-- Contacto directo -->
          <div class="contact-direct fade-in fade-in-delay-2">
            <p class="direct-intro">
              <span class="lang-es">{es.contact.direct.intro}</span>
              <span class="lang-en">{en.contact.direct.intro}</span>
            </p>

            <div class="direct-links">
              <!-- Email -->
              <a
                href="mailto:juancarlosvallejo3@gmail.com"
                class="direct-link"
                aria-label="Enviar email"
              >
                <div class="direct-icon">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                    <polyline points="22,6 12,13 2,6"/>
                  </svg>
                </div>
                <div class="direct-info">
                  <span class="direct-type">Email</span>
                  <span class="direct-value">juancarlosvallejo3@gmail.com</span>
                </div>
              </a>

              <!-- LinkedIn -->
              <a
                href="https://www.linkedin.com/in/carlos-vallejo-ruiz/"
                target="_blank"
                rel="noopener noreferrer"
                class="direct-link"
                aria-label="Perfil de LinkedIn"
              >
                <div class="direct-icon">
                  <!-- LinkedIn icon SVG -->
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M16 8a6 6 0 016 6v7h-4v-7a2 2 0 00-2-2 2 2 0 00-2 2v7h-4v-7a6 6 0 016-6z"/>
                    <rect x="2" y="9" width="4" height="12"/>
                    <circle cx="4" cy="4" r="2"/>
                  </svg>
                </div>
                <div class="direct-info">
                  <span class="direct-type">LinkedIn</span>
                  <span class="direct-value">carlos-vallejo-ruiz</span>
                </div>
              </a>
            </div>

            <!-- Nota de respuesta -->
            <p class="response-note lang-es">
              Respondemos en menos de 48 horas laborables.
            </p>
            <p class="response-note lang-en">
              We respond within 48 business hours.
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .contact-inner {
    max-width: 900px;
    margin-inline: auto;
    display: flex;
    flex-direction: column;
    gap: var(--space-12);
  }

  .contact-header .section-title {
    margin-bottom: var(--space-4);
  }

  /* Dos columnas en desktop */
  .contact-columns {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-10);
  }

  @media (min-width: 768px) {
    .contact-columns {
      grid-template-columns: 1.4fr 1fr;
      align-items: start;
    }
  }

  /* Formulario */
  .contact-form {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-5);
  }

  @media (min-width: 640px) {
    .form-row {
      grid-template-columns: 1fr 1fr;
    }
  }

  .submit-btn {
    width: 100%;
    justify-content: center;
    gap: var(--space-2);
  }

  /* Contacto directo */
  .direct-intro {
    font-size: var(--text-sm);
    color: var(--texto-sec);
    margin-bottom: var(--space-4);
    font-weight: var(--weight-medium);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .direct-links {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    margin-bottom: var(--space-6);
  }

  .direct-link {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-4);
    background-color: var(--bg-panel);
    border: 1px solid var(--borde);
    border-radius: var(--radius-lg);
    text-decoration: none;
    transition: border-color var(--transition-fast), box-shadow var(--transition-fast), transform var(--transition-fast);
  }

  .direct-link:hover {
    border-color: var(--acento);
    box-shadow: 0 0 0 3px rgba(224,123,57,0.08);
    transform: translateY(-1px);
  }

  .direct-icon {
    width: 40px;
    height: 40px;
    background-color: #fff;
    border: 1px solid var(--borde);
    border-radius: var(--radius-md);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--acento);
    flex-shrink: 0;
  }

  .direct-info {
    display: flex;
    flex-direction: column;
    gap: 2px;
    min-width: 0;
  }

  .direct-type {
    font-size: var(--text-xs);
    font-weight: var(--weight-semibold);
    color: var(--texto-sec);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .direct-value {
    font-size: var(--text-sm);
    color: var(--texto);
    font-weight: var(--weight-medium);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .response-note {
    font-size: var(--text-xs);
    color: var(--texto-sec);
    font-style: italic;
  }
</style>
